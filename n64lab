#!/bin/bash
# ═══════════════════════════════════════════════════════════════
# N64 AI Co-op Lab — Unified Launcher
# Controls: SoH, AI DM, Asset Gen, Scraper, Blender, ML64,
#           Swarm Coordinator, and AI World Architect
# ═══════════════════════════════════════════════════════════════

cd ~/HylianModding
VENV=./venv/bin/python

print_help() {
    cat << 'EOF'
Usage: ./n64lab <command> [args]

PLAY & MODS:
  play                Launch Ship of Harkinian
  install-textures    Install all texture packs to SoH mods/
  mods                List installed SoH mods

AI SYSTEMS:
  dm                  AI Dungeon Master (text challenges)
  gen                 Procedural asset generator
  world               AI World Architect — build complete worlds
  campaign            Run multi-round AI campaign
  catalog             Catalog all ROMs, textures, tools
  scrape              Scrape web for new N64 assets

SWARM & DISTRIBUTION:
  swarm-start         Start Swarm Coordinator (port 7373)
  worker              Start local Swarm Worker
  swarm-cli           Swarm CLI (status, tasks, campaign)

TOOLS:
  blender             Launch Blender with Fast64
  ml64                Launch ModLoader64
  analyze             Analyze ROM hack themes
  status              Show system status
  build               Build .o2r texture pack (basic zip)

EXAMPLES:
  ./n64lab world --theme shadow --difficulty 5
  ./n64lab campaign --rounds 3
  ./n64lab catalog
  ./n64lab install-textures
EOF
}

case "$1" in
  play)
    ./launch_soh.sh
    ;;
  
  install-textures)
    echo "[n64lab] Installing texture packs to SoH..."
    $VENV AI_World/texture_packager.py --install OoT_Reloaded
    $VENV AI_World/texture_packager.py --install MM_Reloaded
    $VENV AI_World/texture_packager.py --install Classic64
    echo "[n64lab] Done. Launch SoH and press Tab to toggle alternate assets."
    ;;
  
  mods)
    echo "=== Installed SoH Mods ==="
    ls -la ~/HylianModding/ShipOfHarkinian/mods/ 2>/dev/null || echo "(no mods yet)"
    ;;

  dm)
    cd AI_DM && $VENV run_dm.py --cli
    ;;

  gen)
    cd AI_Assets && $VENV asset_generator.py
    ;;

  world)
    shift
    $VENV AI_World/world_architect.py --build "$@"
    ;;

  campaign)
    shift
    $VENV AI_World/world_architect.py --campaign "$@"
    ;;

  catalog)
    $VENV AI_World/world_architect.py --catalog
    ;;

  scrape)
    $VENV AI_World/world_architect.py --scrape
    ;;

  swarm-start)
    echo "[n64lab] Starting Swarm Coordinator on port 7373..."
    $VENV SwarmCoordinator/coordinator.py &
    echo $! > /tmp/n64lab_coordinator.pid
    echo "PID saved to /tmp/n64lab_coordinator.pid"
    ;;

  worker)
    shift
    $VENV SwarmCoordinator/worker.py "$@"
    ;;

  swarm-cli)
    shift
    $VENV SwarmCoordinator/swarm_cli.py "$@"
    ;;

  blender)
    blender &
    ;;

  ml64)
    cd ModLoader64/ModLoader && ./start.sh
    ;;

  analyze)
    $VENV -c "
import json, os
from pathlib import Path
cat = json.load(open('Library/Metadata/rom_catalog.json'))
from collections import Counter
g = Counter(r.get('genre','unknown') for r in cat)
print('Genres:', dict(g))
t = Counter(t for r in cat for t in r.get('themes',[]))
print('Themes:', dict(t))
"
    ;;

  status)
    echo "═" $(date) "═"
    echo "ROMs:     $(ls Library/ROMs/ 2>/dev/null | wc -l)"
    echo "Textures: $(find Assets/Textures -name '*.png' 2>/dev/null | wc -l)"
    echo "Tools:    $(find Assets/Tools -maxdepth 2 -type d 2>/dev/null | wc -l)"
    echo "Worlds:   $(ls MyWorld/generated_stories/*.json 2>/dev/null | wc -l)"
    echo "Levels:   $(ls MyWorld/generated_levels/*.json 2>/dev/null | wc -l)"
    echo "SoH:      $(test -f ShipOfHarkinian/soh.appimage && echo 'installed' || echo 'missing')"
    echo "Mods:     $(ls ShipOfHarkinian/mods/ 2>/dev/null | wc -l)"
    if [ -f /tmp/n64lab_coordinator.pid ]; then
      pid=$(cat /tmp/n64lab_coordinator.pid)
      if kill -0 "$pid" 2>/dev/null; then
        echo "Swarm:    running (pid $pid)"
      else
        echo "Swarm:    stopped"
      fi
    else
      echo "Swarm:    not started"
    fi
    ;;

  build)
    echo "[n64lab] Building .o2r texture pack..."
    shift
    $VENV AI_World/texture_packager.py --package "$@"
    ;;

  *)
    print_help
    ;;
esac
