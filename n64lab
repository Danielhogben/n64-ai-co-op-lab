#!/bin/bash
# N64 AI Co-op Lab — Unified Launcher
# Usage: ./n64lab [command]

set -e

LAB="$HOME/HylianModding"
VENV="$LAB/venv/bin/python"

case "${1:-menu}" in
    menu|help|-h|--help)
        cat << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║           N64 AI Co-op Lab — Unified Launcher                ║
╠══════════════════════════════════════════════════════════════╣
║  play      → Launch Ship of Harkinian (PC port of OoT)      ║
║  dm        → Start AI Dungeon Master (interactive CLI)       ║
║  gen       → Generate procedural asset                       ║
║  scraper   → Run metadata scraper bot                        ║
║  blender   → Open Blender with project                       ║
║  ml64      → Launch ModLoader64 (N64 emulator + netplay)     ║
║  analyze   → Analyze your .zobj model library                ║
║  status    → System health check                             ║
║  build     → Show build pipeline                             ║
╚══════════════════════════════════════════════════════════════╝
EOF
        ;;

    play)
        echo "🎮 Launching Ship of Harkinian..."
        "$LAB/ShipOfHarkinian/soh.appimage" &
        ;;

    dm)
        echo "🎲 Starting AI Dungeon Master..."
        cd "$LAB/AI_DM"
        "$VENV" run_dm.py --cli
        ;;

    gen)
        echo "🎨 Procedural Asset Generator"
        read -p "Type [crystal/tree/terrain/dungeon_room/spike_trap/biome]: " atype
        read -p "Theme [forest/ice/fire/shadow/crystal_cave/dungeon]: " theme
        read -p "Seed [1-9999]: " seed
        cd "$LAB/AI_Assets"
        "$VENV" asset_generator.py --type "${atype:-crystal}" --theme "${theme:-forest}" --seed "${seed:-42}"
        echo ""
        echo "Output: $LAB/MyWorld/blender/"
        ;;

    scraper)
        echo "🔍 Running metadata scraper..."
        cd "$LAB/ScraperBot"
        "$VENV" scraper.py --gb-pages 3 --output "catalog_$(date +%Y%m%d)"
        echo ""
        echo "Catalog saved to: $LAB/ScraperBot/outputs/"
        ;;

    blender)
        echo "🖌️ Opening Blender..."
        blender "$LAB/MyWorld/blender/" &
        ;;

    ml64)
        echo "🎮 Launching ModLoader64..."
        cd "$LAB/ModLoader64/ModLoader"
        ./start.sh
        ;;

    analyze)
        echo "📊 Analyzing model library..."
        cd "$LAB/AI_Assets"
        "$VENV" asset_analyzer.py
        ;;

    status)
        echo "🏥 System Health Check"
        echo ""
        echo "ROM:          $([ -f $LAB/ShipOfHarkinian/OoT.z64 ] && echo '✅' || echo '❌')"
        echo "SoH:          $([ -x $LAB/ShipOfHarkinian/soh.appimage ] && echo '✅' || echo '❌')"
        echo "Python venv:  $([ -f $LAB/venv/bin/python ] && echo '✅' || echo '❌')"
        echo "Blender:      $(which blender > /dev/null && echo '✅' || echo '❌')"
        echo "Node.js:      $(which node > /dev/null && echo '✅ '$(node --version) || echo '❌')"
        echo "flips:        $(which flips > /dev/null && echo '✅' || echo '❌')"
        echo "GGUF models:  $(find ~/Downloads/models -name '*.gguf' | wc -l) found"
        echo "Blender addons:"
        blender --background --python-expr "
import bpy
for a in ['fast64', 'io_export_so2']:
    print('  ' + ('✅' if a in bpy.context.preferences.addons else '❌') + ' ' + a)
" 2>&1 | grep -E "fast64|io_export_so2"
        echo ""
        echo "Catalog entries:"
        for f in $LAB/ScraperBot/outputs/*.json; do
            [ -f "$f" ] && echo "  $(basename $f): $(python3 -c "import json; print(json.load(open('$f'))['total_entries'])" 2>/dev/null || echo '?') entries"
        done
        ;;

    build)
        "$LAB/build_world.sh"
        ;;

    *)
        echo "Unknown command: $1"
        echo "Run './n64lab' or './n64lab help' for available commands"
        exit 1
        ;;
esac
